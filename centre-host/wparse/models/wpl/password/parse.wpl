package /password/ {
    rule 操作日志 {
        (
            json | take(log) | json_unescape() | (
              time:date<[,]>,
              chars:obj<[,]>,
              chars:level<[,]>,
              chars:content\0
            )  
        )
    }
    rule all {
        (
            #[copy_raw(name:"raw_log")]
            json | take(log) | json_unescape() | (
              chars:content\0
            )
        )
    }
}
